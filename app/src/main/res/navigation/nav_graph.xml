<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/welcomeFragment">

    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.example.guestguide.ui.welcome.WelcomeFragment"
        android:label="Welcome" >
        <!-- ide na login prvo, ne direktno na setup -->
        <action
            android:id="@+id/action_welcome_to_admin"
            app:destination="@id/adminLoginFragment" />
        <action
            android:id="@+id/action_welcome_to_guest"
            app:destination="@id/guestHomeFragment" />
    </fragment>

    <!-- admin login ekran -->
    <fragment
        android:id="@+id/adminLoginFragment"
        android:name="com.example.guestguide.ui.admin.AdminLoginFragment"
        android:label="Admin Login" >

        <!-- nakon logina back dugme preskace login i vraca na welcome -->
        <action
            android:id="@+id/action_login_to_setup"
            app:destination="@id/adminSetupFragment"
            app:popUpTo="@id/welcomeFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminSetupFragment"
        android:name="com.example.guestguide.ui.admin.AdminSetupFragment"
        android:label="Admin Setup" />

    <fragment
        android:id="@+id/guestHomeFragment"
        android:name="com.example.guestguide.ui.guest.GuestHomeFragment"
        android:label="Guest Home" >

        <!-- salje accessCode iz welcome ekrana -->
        <argument
            android:name="accessCode"
            app:argType="string" />

        <action
            android:id="@+id/action_guest_home_to_explore"
            app:destination="@id/guestExploreFragment" />
    </fragment>

    <fragment
        android:id="@+id/guestExploreFragment"
        android:name="com.example.guestguide.ui.guest.GuestExploreFragment"
        android:label="Explore" />
</navigation>